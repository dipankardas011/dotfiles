[global]
    font = "JetBrainsMono NF 10"
    
    # Allow HTML markup in notifications
    markup = full
    
    # rounded corners
    corner_radius = 10
    
    # Format notifications
    format = "<b>%s</b>\n%b"
    
    # Sort messages by urgency
    sort = yes
    
    # Show how many messages are currently hidden
    indicate_hidden = yes
    
    # Alignment of message text
    alignment = left
    
    # Show age of message if message is old
    show_age_threshold = 60
    
    # Split notifications into multiple lines
    word_wrap = yes
    
    # Ignore newlines '\n' in notifications
    ignore_newline = no
    
    # Stack duplicated notifications
    stack_duplicates = true
    
    # Hide duplicate's count and stack them
    hide_duplicate_count = false
    
    # Display indicators for URLs (U) and actions (A)
    show_indicators = yes
    
    # The geometry of the window
    # Format: [{width}]x{height}[+/-{x}+/-{y}]
    geometry = "240x5-22+18"
    
    # Shrink window if it's smaller than the width
    shrink = no
    
    # The transparency of the window (0-100)
    transparency = 0
    
    # Don't remove messages if the user is idle
    idle_threshold = 120
    
    # Display notification on focused monitor
    follow = mouse
    
    # Maximum amount of notifications kept in history
    history_length = 20
    
    # Display indicators for URLs (U) and actions (A)
    show_indicators = yes
    
    # Progress bar height
    progress_bar_height = 6
    progress_bar_frame_width = 1
    progress_bar_min_width = 120
    progress_bar_max_width = 220
    progress_bar_corner_radius = 3

    # Set the frame width of the notification window
    frame_width = 0
    
    # Set the frame color of the notification window
    frame_color = "#7fbbb3"
    separator_color = "#414b50"
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    icon_position = left

[urgency_low]
    background = "#2e383c"
    foreground = "#9da9a0"
    highlight = "#83c092"
    timeout = 5

[urgency_normal]
    background = "#272e33"
    foreground = "#d3c6aa"
    frame_color = "#7fbbb3"
    highlight = "#a7c080"
    timeout = 10

[urgency_critical]
    background = "#2e383c"
    foreground = "#e67e80"
    frame_color = "#e67e80"
    highlight = "#e67e80"
    timeout = 0

# Custom notification categories
[battery]
    appname = "Battery Warning"
    urgency = critical
    background = "#2e383c"
    foreground = "#e67e80"

[volume-notification]
    appname = "Volume"
    urgency = low
    format = "<b>%s</b>"
    timeout = 1

[brightness-notification]
    appname = "Brightness"
    urgency = low
    format = "<b>%s</b>"
    highlight = "#dbbc7f"
    timeout = 1
